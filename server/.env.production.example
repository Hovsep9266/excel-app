# Production on cloud (Render, Railway, VPS, Docker)
# Excel is read from OneDrive share link — no local file on server.

PORT=4000
HOST=0.0.0.0
NODE_ENV=production
FRONTEND_URL=https://your-domain.com

EXCEL_SOURCE=hybrid
EXCEL_LOCAL_PATH=
EXCEL_SHARE_URL=https://onedrive.live.com/...your-public-share-link...
EXCEL_DEFAULT_SHEET=աշխատող
EXCEL_DEFAULT_RANGE=

# Optional — only if you configure Azure app for personal Microsoft accounts
MS_TENANT_ID=consumers
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_REDIRECT_URI=https://your-domain.com/api/auth/callback
MS_SCOPES=offline_access openid profile Files.Read User.Read
