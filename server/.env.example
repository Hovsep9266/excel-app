PORT=4000
FRONTEND_URL=http://localhost:3000
EXCEL_SOURCE=hybrid
# Local copy (often "My files" / Hoso) — can be older than ISO ISO shared file.
EXCEL_LOCAL_PATH=C:/Users/USER/OneDrive/eco clim himnakan.xlsx
# Public share link from ISO ISO file: Share → Anyone with the link can view.
EXCEL_SHARE_URL=
EXCEL_PREFER_SHARE_LINK=true
EXCEL_PUBLIC_FILE_URL=
MS_TENANT_ID=common
MS_CLIENT_ID=your-app-client-id
MS_CLIENT_SECRET=optional-for-public-client
MS_REDIRECT_URI=http://localhost:4000/api/auth/callback
MS_SCOPES=offline_access openid profile Files.Read User.Read
EXCEL_DRIVE_ID=your-drive-id
EXCEL_ITEM_ID=your-item-id-or-doc-id
EXCEL_SHARE_URL=
EXCEL_DEFAULT_SHEET=Sheet1
# Leave empty to read the entire worksheet (recommended for work-month tables).
EXCEL_DEFAULT_RANGE=
